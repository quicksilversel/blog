{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/generate-rss.ts && tsx scripts/generate-search-index.ts && next build",
    "generate-rss": "tsx scripts/generate-rss.ts",
    "generate-search-index": "tsx scripts/generate-search-index.ts",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "run-p lint:eslint lint:stylelint lint:content prettier",
    "lint:fix": "run-p lint:eslint:fix lint:stylelint:fix prettier:fix",
    "lint:content": "tsx scripts/lint-content.ts",
    "lint:eslint": "eslint \"./src/**/*.{ts,tsx}\"",
    "lint:eslint:fix": "eslint --fix \"./src/**/*.{ts,tsx}\"",
    "lint:stylelint": "stylelint \"src/**/*.{ts,tsx,js,jsx}\" 2>&1 | grep -v 'Unknown rule' || true",
    "lint:stylelint:fix": "stylelint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "clean": "rm -rf .next .turbo node_modules/.cache",
    "clean:cache": "rm -rf .next/cache"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "feed": "^5.1.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.544.0",
    "next": "^16.2.9",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "reading-time": "^1.5.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-unused-imports": "4.2.0",
    "npm-run-all": "^4.1.5",
    "postcss-styled-syntax": "^0.7.1",
    "prettier": "^3.8.3",
    "stylelint": "^17.8.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-order": "^8.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vitest": "^4.1.9"
  }
}
